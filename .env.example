# --- Feed selection -------------------------------------------------------
# TRADE_FEED: mock | celer
TRADE_FEED=mock
# MARKET_DATA: mock | blpapi
MARKET_DATA=mock

# --- Mock server (local dev) ----------------------------------------------
MOCK_REST_URL=http://localhost:8000
MOCK_WS_URL=ws://localhost:8000/ws/trades

# --- Real Celer (work) ------------------------------------------------------
# Fill these in at work. Auth headers are sent on the websocket handshake.
CELER_WS_URL=
CELER_REST_URL=
CELER_AUTH_HEADER_NAME=Authorization
CELER_AUTH_HEADER_VALUE=
# Capture every raw frame to data/celer_frames.jsonl before parsing (day-1 tool)
CAPTURE_RAW=true

# --- Bloomberg Desktop API (work) -------------------------------------------
BLPAPI_HOST=localhost
BLPAPI_PORT=8194
# Seconds around booked_at to search for ticks
BLPAPI_TICK_WINDOW_SEC=120

# --- App -------------------------------------------------------------------
VOICE_ENABLED=true
DIGEST_THRESHOLD=5
DB_PATH=data/trades.db
